# Note: All variables to this image are optional.
# See README for more information.
# To use, copy this file to 'mcp.env' and uncomment/set your values.

# API key for all gateway requests (auto-generated on first start if not set).
# Use 'docker exec <container> mcp_manage --showkey' to display it.
# MCP_API_KEY=my-secret-key

# TCP port for the MCP gateway (default: 3000)
# MCP_PORT=3000

# Hostname or IP shown in startup info and 'mcp_manage --showkey' output.
# If not set, the server's public IP is detected automatically.
# MCP_HOST=mcp.example.com

# Anonymous aggregate usage counts (default: enabled)
# Set to 1 to disable.
# MCP_DISABLE_USAGE_COUNTS=1

# MCPHub dashboard admin password (auto-generated on first start if not set).
# To reset: remove /var/lib/mcp/mcp_settings.json and restart.
# MCP_ADMIN_PASSWORD=my-dashboard-password

# Enabled MCP servers (comma-separated). Each may require credentials below.
# Available servers:
#   filesystem    - File system access (requires MCP_FILESYSTEM_DIRS)
#   fetch         - HTTP fetch tool (no config needed)
#   github        - GitHub API (requires MCP_GITHUB_TOKEN)
#   brave-search  - Brave Search API (requires MCP_BRAVE_API_KEY)
#   git           - Git repository tools (requires MCP_GIT_REPO)
#   postgres      - PostgreSQL access (requires MCP_POSTGRES_URL)
#   memory        - Knowledge graph / memory store (no config needed)
#   sequential-thinking - Structured thinking tool (no config needed)

# MCP_SERVERS=filesystem,fetch

# Per-server configuration (only needed for servers listed above)

# filesystem: allowed directories (comma-separated, mapped into container)
# These paths must be bind-mounted into the container.
# MCP_FILESYSTEM_DIRS=/data/docs,/data/code

# github: personal access token
# MCP_GITHUB_TOKEN=ghp_...

# brave-search: API key from https://brave.com/search/api/
# MCP_BRAVE_API_KEY=BSA...

# git: path to repository inside container (bind-mount from host)
# MCP_GIT_REPO=/repo

# postgres: connection string
# MCP_POSTGRES_URL=postgresql://user:pass@host:5432/db
